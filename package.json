{
  "name": "ottawa-new-build-map",
  "version": "1.0.0",
  "description": "Interactive map of new build communities in Ottawa with price history and model comparison",
  "type": "module",
  "scripts": {
    "scrape": "node scraper/index.js",
    "scrape:source": "node --input-type=module",
